            .by-card-content-v02
              .lexicon-entry-header
                %a{href: '/lexicon'}
                  .lexicon-header-he
                    .headline-1-v02 לקסיקון הספרות העברית החדשה
                    .index-part-of-pby
                      %img{:alt => "", :src => "/assets/ornament_1.svg"}
                      .headline-3-v02 חלק מפרויקט בן־יהודה
                      %img{:alt => "", :src => "/assets/ornament_1.svg"}
                -#.lexicon-entry-under-construction-desktop
                -#  .by-icon-v02 '
                -#  ערך בהכנה
              .lexicon-author-details
                -# unless @lex_entry.images.empty?
                  %div
                    %img.lexicon-author-pic{:alt => "", :src => url_for(@lex_entry.images[0])}
                %div
                  .author-name-years
                    .headline-1-v02= @lex_entry.title
                    .date-range!= @lex_person.life_years
                  - if @lex_person.person.present?
                    .to-pby
                      - authority = @lex_person.person.authority
                      = link_to t(:to_pby_person), authority
                  .metadata
                    = render partial: 'shared/intellectual_property',
                             locals: { intellectual_property: @lex_person.intellectual_property }
              %p!= MarkdownToHtml.call(@lex_person.bio)
          #works.by-card-v02
